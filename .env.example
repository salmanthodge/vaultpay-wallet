# ---- Runtime ----
NODE_ENV=development
PORT=4002
SERVICE_NAME=wallet-service
LOG_LEVEL=debug
# ---- Logging ----
# write logs to daily-rotated files under LOG_DIR (in addition to the console)
LOG_TO_FILE=true
LOG_DIR=logs
# print every Prisma SQL query (text + params + duration) to console/files
DB_LOG_QUERIES=true

# ---- Database (wallet owns its own DB on the shared Postgres server) ----
DATABASE_URL=postgresql://vaultpay:vaultpay@localhost:5432/vaultpay_wallet?schema=public

# ---- Redis (rate-limit / cache) ----
REDIS_URL=redis://localhost:6379

# ---- Customer JWT (verify only — must match auth-service's access secret) ----
JWT_ACCESS_SECRET=change-me-access

# ---- Service-to-service (S2S) ----
S2S_SECRET=change-me-s2s
# credentials this service uses to obtain S2S tokens from auth-service
S2S_CLIENT_ID=wallet-service
S2S_CLIENT_SECRET=dev-s2s-secret-change-me
AUTH_SERVICE_URL=http://localhost:4001

# ---- Encryption middleware toggle ----
ENCRYPTION_ENABLED=false
ENCRYPTION_KEY=change-me-32-byte-key-000000000000

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- Cluster ----
CLUSTER_ENABLED=false
CLUSTER_WORKERS=0
